<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero Image Section -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="280dp">

            <!-- Site Image -->
            <ImageView
                android:id="@+id/img_detail_hero"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="@string/app_name" />

            <!-- Gradient Overlay at bottom -->
            <View
                android:id="@+id/view_detail_overlay"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_overlay_bottom" />

            <!-- Category Badge on image -->
            <TextView
                android:id="@+id/tv_detail_category_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_category_badge"
                android:paddingStart="12dp"
                android:paddingTop="4dp"
                android:paddingEnd="12dp"
                android:paddingBottom="4dp"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Back Button on image -->
            <ImageButton
                android:id="@+id/ib_detail_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="start|top"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:background="#4D000000"
                android:contentDescription="@string/retry_button"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@android:color/white" />

            <!-- Favorite Button on image -->
            <ImageButton
                android:id="@+id/ib_detail_favorite"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="end|top"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:background="#4D000000"
                android:contentDescription="@string/nav_favorites"
                android:padding="8dp"
                android:src="@android:drawable/btn_star_big_off"
                app:tint="@android:color/white" />

        </FrameLayout>

        <!-- Content Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp">

            <!-- Site Name -->
            <TextView
                android:id="@+id/tv_detail_site_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#8B7355"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="serif" />

            <!-- City and Foundation Year Chips Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <!-- City Chip -->
                <TextView
                    android:id="@+id/tv_detail_city_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_selected"
                    android:paddingStart="14dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="6dp"
                    android:textColor="@android:color/white"
                    android:textSize="12sp" />

                <!-- Foundation Year Chip -->
                <TextView
                    android:id="@+id/tv_detail_year_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:paddingStart="14dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="6dp"
                    android:textColor="#555555"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Decorative Divider -->
            <View
                android:layout_width="60dp"
                android:layout_height="3dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"
                android:background="#A52A2A" />

            <!-- Description Section -->
            <TextView
                android:id="@+id/tv_detail_description_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/description_label"
                android:textColor="#8B7355"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_detail_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="8dp"
                android:textColor="#444444"
                android:textSize="15sp" />

            <!-- History Section -->
            <TextView
                android:id="@+id/tv_detail_history_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/history_label"
                android:textColor="#8B7355"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_detail_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="8dp"
                android:textColor="#444444"
                android:textSize="15sp" />

            <!-- Open in Google Maps Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_open_maps"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp"
                android:text="@string/google_maps_label"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="#556B2F"
                app:cornerRadius="26dp"
                app:icon="@android:drawable/ic_menu_mapmode"
                app:iconGravity="textStart"
                app:iconPadding="8dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
